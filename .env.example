# ── Servidor ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de datos PostgreSQL ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=dk_fitt_db
DB_USER=postgres
DB_PASSWORD=12345678

# ── JWT ───────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ── Seguridad ─────────────────────────────────────────────────
INSTITUTIONAL_DOMAIN=decokasas.com
BCRYPT_SALT_ROUNDS=12

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=5

Crea `.gitignore`:
```
node_modules/
dist/
.env
*.log
.DS_Store
